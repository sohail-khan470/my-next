generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String?
  password String
  notes    Note[]

  @@map("users")
}

model Note {
  id           Int      @id @default(autoincrement())
  title        String
  content      String
  created      DateTime @default(now())
  userId       Int
  is_completed Boolean?
  user         User     @relation(fields: [userId], references: [id])

  @@map("notes")
}
